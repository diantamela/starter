# Copy this file to .env and update the values.
# You can use a service account JSON file with GOOGLE_APPLICATION_CREDENTIALS.

GCP_PROJECT_ID=your-google-cloud-project-id
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LOCATION=us-central1
GEMINI_SYSTEM_INSTRUCTION=You are Gemini, a helpful AI assistant. Answer naturally and keep responses concise and relevant.
GEMINI_TEMPERATURE=0.2
# Option 1: Use Application Default Credentials or a service account file.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option 2: Use an API key if your Vertex AI endpoint supports it.
# GOOGLE_API_KEY=your-api-key
